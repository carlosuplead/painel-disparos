        "options": {}
      },
      "id": "http-cron",
      "name": "Disparar agendamentos pendentes",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    }
  ],
  "connections": {
    "A cada 5 minutos": {
      "main": [[{ "node": "Disparar agendamentos pendentes", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
